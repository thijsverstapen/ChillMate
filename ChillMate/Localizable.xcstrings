    "ChillMate does not encourage substance use, sex, or mixing substances." : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillMate moedigt middelengebruik, seks of het combineren van middelen niet aan."
          }
        }
      }
    },
    "ChillMate does not provide dosing, medical, legal, or emergency-services advice." : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillMate geeft geen advies over dosering, medische, juridische of nooddiensten."
          }
        }
      }
    },
    "ChillMate is a private reflection and wellbeing tool. It does not diagnose, treat, recommend substance use, or give dosage advice. For urgent help, use emergency services or Support." : {
      "comment" : "A safety notice displayed in the footer of the app.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillMate is a private reflection and wellbeing tool. It does not diagnose, treat, recommend substance use, or give dosage advice. For urgent help, use emergency services or Support."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillMate is een privé-tool voor reflectie en welzijn. Het stelt geen diagnose, behandelt niet, beveelt geen middelengebruik aan en geeft geen doseringsadvies. Voor dringende hulp, gebruik de hulpdiensten of Hulp."
          }
        }
      }
    },
    "ChillMate is already checking your location." : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillMate controleert je locatie al."
          }
        }
      }
    },
    "ChillMate is for adults only. You are responsible for the information you save and who you share it with." : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillMate is alleen voor volwassenen. Jij bent verantwoordelijk voor de informatie die je opslaat en met wie je die deelt."
          }
        }
      }
    },
    "ChillMate is for adults. You need to be 18 or older to create an account." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ChillMate is for adults. You need to be 18 or older to create an account."
          }
        },
        "nl" : {
