            "value" : "ChillMate is voor volwassenen. Je moet 18 jaar of ouder zijn om een account aan te maken."
          }
        }
      }
    },
    "ChillMate is free for everyone. A tip is a small, completely optional way to say thanks." : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
