    "Every Chill in the last 14 days has either a log or a skipped check-in." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every Chill in the last 14 days has either a log or a skipped check-in."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elke Chill van de afgelopen 14 dagen heeft een log of een overgeslagen check-in."
          }
        }
      }
    },
    "Every choice that protects your body is worth something, even the small ones." : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elke keuze die je lichaam beschermt is iets waard, ook de kleine."
          }
        }
      }
    },
    "Everything you saved, in one place" : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alles wat je hebt opgeslagen, op één plek"
          }
        }
      }
    },
    "Example: ask me 'green, yellow, or red?'" : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voorbeeld: vraag me 'groen, geel of rood?'"
          }
        }
      }
    },
    "Example: I can call my trusted contact, order a ride, or leave with a friend" : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voorbeeld: ik kan mijn vertrouwenscontact bellen, een rit bestellen of met een vriend weggaan"
          }
        }
      }
    },
    "Example: leave earlier, eat first, avoid app dates after midnight" : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voorbeeld: eerder weggaan, eerst eten, geen app-dates na middernacht"
          }
        }
      }
    },
    "Example: no stimulant-related Chills for two weeks" : {
