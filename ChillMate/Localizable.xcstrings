        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neem zo snel mogelijk contact op met de GGD, huisarts of het ziekenhuis. PEP werkt het best als het snel wordt gestart en is meestal beperkt tot 72 uur."
          }
        }
