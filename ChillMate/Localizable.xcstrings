    },
    "I build ChillMate on my own, on late nights and weekends, because I wanted a calm, private place to look after yourself, with no judgment. It's completely free: no ads, nothing locked behind a paywall, and it will stay that way." : {
      "comment" : "A description of the benefits of using ChillMate.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I build ChillMate on my own, on late nights and weekends, because I wanted a calm, private place to look after yourself, with no judgment. It's completely free: no ads, nothing locked behind a paywall, and it will stay that way."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ik bouw ChillMate in mijn eentje, op late avonden en in weekenden, omdat ik een rustige, privéplek wilde om voor jezelf te zorgen, zonder oordeel. Het is volledig gratis: geen advertenties, niets achter een betaalmuur, en dat blijft zo."
          }
        }
      }
