        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jouw basislijn"
          }
        }
      }
    },
    "Your body remembers every kind decision you make, even the ones you forget." : {
      "localizations" : {
        "nl" : {
